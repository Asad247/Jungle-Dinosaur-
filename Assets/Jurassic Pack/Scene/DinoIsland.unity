  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 166
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 282
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: 'This demo represents a player controller with a weapon script, and how
    it can be used

    in integration with RSB. It also doesn''t contain any terrain
    or complex meshes, so it can be run easily on mobile platforms. Sniper and Ballistics
    System instance provides the main functionality

    meanwhile it''s children
    objects are responsible for pooling particles & listening to hit events.

    Bullet
    Time Camera Default listens to bullet time events to trigger itself, meanwhile
    Dynamic Scope System is used by the

    weapon under player controller to display
    aim scope.'
